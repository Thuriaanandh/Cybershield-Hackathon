# /etc/liveboot_sentinel/agent.env
# LiveBoot Sentinel Agent Environment Configuration
# SECURITY: chmod 600 this file — readable by root only

# Alert server URL (must be HTTPS in production)
LIVEBOOT_ALERT_URL=https://your-sentinel-server:8443/alert

# API key for this agent (must match a key in server's LIVEBOOT_API_KEYS)
LIVEBOOT_API_KEY=change-this-to-a-strong-random-key

# Optional: custom CA bundle for self-signed server certificates
# LIVEBOOT_CA_BUNDLE=/etc/liveboot_sentinel/ca.crt

# Set to "false" only for local development — NEVER in production
# LIVEBOOT_VERIFY_SSL=true
